---
import { getLqipProps } from "@/utils/lqip-utils";

interface Props {
	src: string;
	albumId: string;
	alt?: string;
}

const { src, albumId, alt = "" } = Astro.props;

// LQIP 渐变占位
const lqipProps = getLqipProps(src, undefined, true);
---

<div class="gallery-photo-card">
  <div
    data-fancybox={`gallery-${albumId}`}
    data-src={src}
    data-type="image"
    class="gallery-photo-trigger"
  >
    <div class="lqip-placeholder" style={lqipProps.style} aria-hidden="true"></div>
    <img
      src={src}
      alt={alt}
      loading="lazy"
      decoding="async"
      class="gallery-photo-image"
    />
  </div>
</div>
